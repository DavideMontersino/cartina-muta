# Multiplayer (cartina-muta-rooms Worker) — local dev only.
# In production the Pages site forwards /api/* to the Worker same-origin, so
# these are unset. For local dev against `npm run rooms:dev`, copy this file to
# `.env.local` (gitignored) to point the client at the Worker directly:
VITE_ROOMS_HTTP_BASE=http://localhost:8799
VITE_ROOMS_WS_BASE=ws://localhost:8799
