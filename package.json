{
  "name": "campanilismi",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "biome check src/ scripts/ functions/ workers/",
    "lint:fix": "biome check --write src/ scripts/ functions/ workers/",
    "test": "vitest run",
    "test:watch": "vitest",
    "extract-map": "tsx scripts/extract-map.ts",
    "db:migrate": "wrangler d1 migrations apply cartina-muta-auth --remote",
    "db:migrate:local": "wrangler d1 migrations apply cartina-muta-auth --local",
    "rooms:dev": "wrangler dev -c workers/rooms/wrangler.toml",
    "rooms:deploy": "wrangler deploy -c workers/rooms/wrangler.toml",
    "deploy": "npm run build && wrangler pages deploy dist/ --project-name=cartina-muta"
  },
  "dependencies": {
    "better-auth": "1.6.23",
    "d3-geo": "^3.1.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@cloudflare/workers-types": "^4.20260702.1",
    "@types/d3-geo": "^3.1.0",
    "@types/node": "^22.20.0",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.6",
    "@types/topojson-client": "^3.1.5",
    "@types/topojson-server": "^3.0.4",
    "@types/topojson-simplify": "^3.0.3",
    "@vitejs/plugin-react": "^4.5.2",
    "topojson-client": "^3.1.0",
    "topojson-server": "^3.0.1",
    "topojson-simplify": "^3.0.3",
    "tsx": "^4.22.4",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "vitest": "^4.1.0",
    "wrangler": "^3.90.0"
  }
}
